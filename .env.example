# Gmail API Configuration
# Google Cloud ConsoleでサービスアカウントJSONを生成して、下記に貼り付けてください
# JSONは改行なしの1行にしてください
GMAIL_CREDENTIALS_JSON='{"type":"service_account","project_id":"your-project-id",...}'

# Pushover Configuration
# Pushover.netでアカウント登録後に取得
PUSHOVER_USER_KEY=your_user_key_here
PUSHOVER_API_KEY=your_app_token_here

# Worker Configuration
# メール監視の間隔（秒単位）
CHECK_INTERVAL_SECONDS=60
